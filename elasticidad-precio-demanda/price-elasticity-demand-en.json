{
  "$schema": "https://vega.github.io/schema/vega/v6.json",
  "usermeta": {
    "version": "1.0",
    "developedBy": "Jose Rafael Escalante",
    "gitHub": "https://github.com/jrescalante",
    "linkedIn": "https://www.linkedin.com/in/jrescalante/",
    "email": "jrescalante@sentidoanalitica.com",
    "visualName": "Price-Demand Elasticity Scatter",
    "visualDescription": "Price-demand elasticity scatter with period-over-period change, elasticity classification, and context KPIs; ready for Deneb.",
    "doc": {
      "data_stage": [
        "Dataset expects Date, SKU, Product, Category, Unit_Price, Units_Sold, and Revenue.",
        "Validates types, converts numeric fields, sorts by SKU/Date, and computes the previous period with window lag."
      ],
      "layout_signals": [
        "Signals container/viewW/viewH control responsive sizing for the visual.",
        "KPI and context signals manage header placement, text, and the reading layer."
      ],
      "transform_stage": [
        "Computes price change, demand change, arc elasticity, revenue change, and classification.",
        "Applies quality filters (valid, positive values and bounded changes) for comparable points."
      ],
      "visual_stage": [
        "Main scatter: X = price change, Y = demand change.",
        "Color/shape by classification, size by revenue, quadrants, reference rules, and a context point."
      ],
      "tooltip_stage": [
        "Tooltips are intentionally disabled for a cleaner and more uniform public version."
      ],
      "deneb_usage": [
        "Paste the spec into Deneb and bind the 7 required model columns.",
        "Do not use a local URL in dataset.values; the binding comes from the Power BI/Deneb model."
      ],
      "doc_data": {
        "dataset": "Normalizes base fields and derives metrics for elasticity and period-over-period changes.",
        "scatter_stats": "Aggregated summary for change averages and price-change event counts.",
        "latest_sku_points": "Keeps the latest point per SKU and derives exposure KPIs.",
        "sku_kpi_stats": "Aggregates counts/percentages and revenue-weighted elasticity metrics.",
        "active_categories": "Visible active categories according to the current context filters.",
        "active_products": "Visible active products according to the current context filters.",
        "latest_context_point": "Most recent point for contextual visual emphasis."
      }
    }
  },
  "description": "Price-Demand Elasticity Scatter base. Uses Date, SKU, Product, Category, Unit_Price, Units_Sold, and Revenue.",
  "bounds": "flush",
  "autosize": { "type": "fit", "contains": "padding", "resize": true },
  "padding": { "top": 20, "right": 28, "bottom": 56, "left": 28 },
  "width": { "signal": "viewW" },
  "height": { "signal": "viewH" },
  "background": "white",
  "data": [
    {
      "name": "dataset",
      "values": [],
      "transform": [
        { "type": "formula", "as": "fecha_val", "expr": "isDate(datum.Date) ? datum.Date : (test('^\\d{2}/\\d{2}/\\d{4}$', toString(datum.Date)) ? timeParse(toString(datum.Date), '%d/%m/%Y') : toDate(datum.Date))" },
        { "type": "formula", "as": "sku_key", "expr": "toString(datum.SKU)" },
        { "type": "formula", "as": "producto", "expr": "isValid(datum.Product) ? toString(datum.Product) : ''" },
        { "type": "formula", "as": "categoria", "expr": "isValid(datum.Category) ? toString(datum.Category) : ''" },
        { "type": "formula", "as": "precio", "expr": "toNumber(datum.Unit_Price)" },
        { "type": "formula", "as": "unidades", "expr": "toNumber(datum.Units_Sold)" },
        { "type": "formula", "as": "ingresos", "expr": "toNumber(datum.Revenue)" },
        { "type": "filter", "expr": "isValid(datum.fecha_val) && isValid(datum.sku_key) && isValid(datum.precio) && isValid(datum.unidades) && isValid(datum.ingresos) && datum.precio > 0 && datum.unidades > 0 && datum.ingresos > 0" },
        { "type": "collect", "sort": { "field": ["sku_key", "fecha_val"], "order": ["ascending", "ascending"] } },
        {
          "type": "window",
          "groupby": ["sku_key"],
          "sort": { "field": ["fecha_val"], "order": ["ascending"] },
          "ops": ["lag", "lag", "lag"],
          "fields": ["precio", "unidades", "ingresos"],
          "as": ["precio_prev", "unidades_prev", "ingresos_prev"]
        },
        { "type": "formula", "as": "delta_precio_pct", "expr": "isValid(datum.precio_prev) && datum.precio_prev != 0 ? (datum.precio - datum.precio_prev) / datum.precio_prev : null" },
        { "type": "formula", "as": "delta_demanda_pct", "expr": "isValid(datum.unidades_prev) && datum.unidades_prev != 0 ? (datum.unidades - datum.unidades_prev) / datum.unidades_prev : null" },
        { "type": "formula", "as": "promedio_precio", "expr": "isValid(datum.precio_prev) ? (datum.precio + datum.precio_prev) / 2 : null" },
        { "type": "formula", "as": "promedio_unidades", "expr": "isValid(datum.unidades_prev) ? (datum.unidades + datum.unidades_prev) / 2 : null" },
        {
          "type": "formula",
          "as": "elasticidad_arco",
          "expr": "isValid(datum.promedio_precio) && isValid(datum.promedio_unidades) && datum.promedio_precio != 0 && datum.promedio_unidades != 0 && isValid(datum.precio_prev) && datum.precio != datum.precio_prev ? (((datum.unidades - datum.unidades_prev) / datum.promedio_unidades) / ((datum.precio - datum.precio_prev) / datum.promedio_precio)) : null"
        },
        { "type": "formula", "as": "delta_ingresos_pct", "expr": "isValid(datum.ingresos_prev) && datum.ingresos_prev != 0 ? (datum.ingresos - datum.ingresos_prev) / datum.ingresos_prev : null" },
        { "type": "formula", "as": "price_change_flag", "expr": "isValid(datum.delta_precio_pct) && abs(datum.delta_precio_pct) > 0.0001 ? 1 : 0" },
        {
          "type": "formula",
          "as": "clasificacion",
          "expr": "!isValid(datum.elasticidad_arco) ? 'No base' : datum.elasticidad_arco >= 0 ? 'Atypical' : abs(datum.elasticidad_arco) > 1.05 ? 'Elastic' : abs(datum.elasticidad_arco) >= 0.95 ? 'Unit Elastic' : 'Inelastic'"
        },
        { "type": "formula", "as": "abs_elasticidad", "expr": "isValid(datum.elasticidad_arco) ? abs(datum.elasticidad_arco) : null" },
        { "type": "formula", "as": "periodo", "expr": "timeFormat(datum.fecha_val, '%b %Y')" },
        { "type": "filter", "expr": "isValid(datum.precio_prev) && isValid(datum.unidades_prev) && isValid(datum.delta_precio_pct) && isValid(datum.delta_demanda_pct) && datum.price_change_flag == 1 && abs(datum.delta_precio_pct) <= 0.5 && abs(datum.delta_demanda_pct) <= 0.5" }
      ]
    },
    {
      "name": "scatter_stats",
      "source": "dataset",
      "transform": [
        {
          "type": "aggregate",
          "fields": ["delta_precio_pct", "delta_demanda_pct", "elasticidad_arco", "ingresos", "price_change_flag"],
          "ops": ["mean", "mean", "mean", "sum", "sum"],
          "as": ["avg_delta_precio", "avg_delta_demanda", "avg_elasticidad", "total_ingresos", "price_change_events"]
        },
        { "type": "joinaggregate", "ops": ["count"], "as": ["puntos"] }
      ]
    },
    {
      "name": "latest_sku_points",
      "source": "dataset",
      "transform": [
        {
          "type": "window",
          "groupby": ["sku_key"],
          "sort": { "field": ["fecha_val"], "order": ["descending"] },
          "ops": ["row_number"],
          "as": ["sku_rank_desc"]
        },
        { "type": "filter", "expr": "datum.sku_rank_desc == 1" },
        { "type": "formula", "as": "is_elastic", "expr": "datum.clasificacion == 'Elastic' ? 1 : 0" },
        { "type": "formula", "as": "is_risk", "expr": "datum.delta_precio_pct > 0 && datum.delta_demanda_pct < 0 ? 1 : 0" },
        { "type": "formula", "as": "is_capture", "expr": "datum.delta_precio_pct > 0 && datum.delta_demanda_pct > 0 ? 1 : 0" },
        { "type": "formula", "as": "has_price_change", "expr": "datum.price_change_flag == 1 ? 1 : 0" },
        { "type": "formula", "as": "exposed_ingresos", "expr": "datum.is_risk == 1 || datum.is_elastic == 1 ? datum.ingresos : 0" },
        { "type": "formula", "as": "weighted_elasticidad", "expr": "isValid(datum.elasticidad_arco) ? datum.elasticidad_arco * datum.ingresos : 0" },
        { "type": "formula", "as": "valid_elasticidad_ingresos", "expr": "isValid(datum.elasticidad_arco) ? datum.ingresos : 0" }
      ]
    },
    {
      "name": "latest_context_point",
      "source": "dataset",
      "transform": [
        {
          "type": "window",
          "sort": { "field": ["fecha_val", "ingresos"], "order": ["descending", "descending"] },
          "ops": ["row_number"],
          "as": ["context_rank_desc"]
        },
        { "type": "filter", "expr": "datum.context_rank_desc == 1" }
      ]
    },
    {
      "name": "sku_kpi_stats",
      "source": "latest_sku_points",
      "transform": [
        {
          "type": "aggregate",
          "fields": [
            "sku_key",
            "is_elastic",
            "is_risk",
            "is_capture",
            "has_price_change",
            "exposed_ingresos",
            "weighted_elasticidad",
            "valid_elasticidad_ingresos",
            "ingresos"
          ],
          "ops": [
            "count",
            "sum",
            "sum",
            "sum",
            "sum",
            "sum",
            "sum",
            "sum",
            "sum"
          ],
          "as": [
            "sku_count",
            "elastic_sku_count",
            "risk_sku_count",
            "capture_sku_count",
            "price_change_sku_count",
            "exposed_ingresos",
            "weighted_elasticidad_sum",
            "valid_elasticidad_ingresos_sum",
            "visible_ingresos"
          ]
        }
      ]
    },
    {
      "name": "active_categories",
      "source": "dataset",
      "transform": [
        { "type": "aggregate", "groupby": ["categoria"] }
      ]
    },
    {
      "name": "active_products",
      "source": "dataset",
      "transform": [
        { "type": "aggregate", "groupby": ["producto", "categoria"] }
      ]
    },
    {
      "name": "product_trace_points",
      "source": "dataset",
      "transform": [
        { "type": "filter", "expr": "activeProductCount === 1" },
        {
          "type": "window",
          "sort": { "field": ["fecha_val", "ingresos"], "order": ["ascending", "ascending"] },
          "ops": ["row_number"],
          "as": ["trace_step"]
        },
        { "type": "formula", "as": "trace_x", "expr": "datum.delta_precio_pct" },
        { "type": "formula", "as": "trace_y", "expr": "datum.delta_demanda_pct" },
        { "type": "formula", "as": "trace_xy", "expr": "datum.trace_x * datum.trace_y" },
        { "type": "formula", "as": "trace_x2", "expr": "datum.trace_x * datum.trace_x" }
      ]
    },
    {
      "name": "product_trend_stats",
      "source": "product_trace_points",
      "transform": [
        {
          "type": "aggregate",
          "fields": [null, "trace_x", "trace_y", "trace_xy", "trace_x2"],
          "ops": ["count", "sum", "sum", "sum", "sum"],
          "as": ["n", "sum_x", "sum_y", "sum_xy", "sum_x2"]
        }
      ]
    },
    {
      "name": "product_trend_extent",
      "source": "product_trace_points",
      "transform": [
        {
          "type": "aggregate",
          "fields": ["delta_precio_pct", "delta_precio_pct"],
          "ops": ["min", "max"],
          "as": ["x_min", "x_max"]
        }
      ]
    },
    {
      "name": "product_trend_line",
      "values": [
        { "p": 0 },
        { "p": 1 }
      ]
    },
    {
      "name": "active_quadrants",
      "source": "dataset",
      "transform": [
        {
          "type": "formula",
          "as": "quadrant",
          "expr": "datum.delta_precio_pct < 0 && datum.delta_demanda_pct >= 0 ? 'topLeft' : datum.delta_precio_pct >= 0 && datum.delta_demanda_pct >= 0 ? 'topRight' : datum.delta_precio_pct < 0 && datum.delta_demanda_pct < 0 ? 'bottomLeft' : 'bottomRight'"
        },
        { "type": "aggregate", "groupby": ["quadrant"] }
      ]
    },
    {
      "name": "quadrant_labels",
      "values": [
        { "quadrant": "bottomRight", "label": "Volume risk", "subLabel": "Price rises and demand contracts" },
        { "quadrant": "topLeft", "label": "Promotional push", "subLabel": "Price falls and demand responds" },
        { "quadrant": "bottomLeft", "label": "Mixed deterioration", "subLabel": "Neither price nor demand supports the result" },
        { "quadrant": "topRight", "label": "Value capture", "subLabel": "Price rises with resilient demand" }
      ]
    },
    {
      "name": "class_legend_items",
      "values": [
        { "label": "Elastic", "criterion": "|E| > 1.05", "shape": "triangle-up", "detailShape": "triangle-down", "fill": "#e36b76", "stroke": "#a93f4b", "detailFill": "#f8f4f1", "y": 126 },
        { "label": "Unit Elastic", "criterion": "0.95 <= |E| <= 1.05", "shape": "diamond", "detailShape": "diamond", "fill": "#f9d5b1", "stroke": "#b87235", "detailFill": "#b87235", "y": 156 },
        { "label": "Inelastic", "criterion": "|E| < 0.95", "shape": "circle", "detailShape": "circle", "fill": "#c2d9e9", "stroke": "#3f6f95", "detailFill": "#3f6f95", "y": 186 },
        { "label": "Atypical", "criterion": "E >= 0", "shape": "square", "detailShape": "cross", "fill": "#e5cef7", "stroke": "#764695", "detailFill": "#764695", "y": 216 }
      ]
    }
  ],
  "signals": [
    { "name": "container", "update": "containerSize()" },
    { "name": "viewW", "update": "container[0]" },
    { "name": "viewH", "update": "container[1]" },
    { "name": "summaryCenterX", "update": "width * 0.5" },
    { "name": "summaryContextY", "update": "-50" },
    { "name": "summaryKpiY", "update": "-30" },
    { "name": "kpiRowLeft", "update": "-64" },
    { "name": "kpiRowRight", "update": "width + 84" },
    { "name": "kpiRowWidth", "update": "kpiRowRight - kpiRowLeft" },
    { "name": "kpiCol1", "update": "kpiRowLeft + kpiRowWidth * 0.09" },
    { "name": "kpiCol2", "update": "kpiRowLeft + kpiRowWidth * 0.28" },
    { "name": "kpiCol3", "update": "kpiRowLeft + kpiRowWidth * 0.47" },
    { "name": "kpiCol4", "update": "kpiRowLeft + kpiRowWidth * 0.66" },
    { "name": "kpiCol5", "update": "kpiRowLeft + kpiRowWidth * 0.88" },
    { "name": "meanX", "update": "data('scatter_stats').length ? data('scatter_stats')[0].avg_delta_precio : 0" },
    { "name": "meanY", "update": "data('scatter_stats').length ? data('scatter_stats')[0].avg_delta_demanda : 0" },
    { "name": "priceChangeEvents", "update": "data('scatter_stats').length ? data('scatter_stats')[0].price_change_events : 0" },
    { "name": "pointCount", "update": "data('dataset').length" },
    { "name": "skuCount", "update": "data('sku_kpi_stats').length ? data('sku_kpi_stats')[0].sku_count : 0" },
    { "name": "elasticSkuPct", "update": "data('sku_kpi_stats').length && data('sku_kpi_stats')[0].sku_count ? data('sku_kpi_stats')[0].elastic_sku_count / data('sku_kpi_stats')[0].sku_count : 0" },
    { "name": "riskSkuPct", "update": "data('sku_kpi_stats').length && data('sku_kpi_stats')[0].sku_count ? data('sku_kpi_stats')[0].risk_sku_count / data('sku_kpi_stats')[0].sku_count : 0" },
    { "name": "captureSkuPct", "update": "data('sku_kpi_stats').length && data('sku_kpi_stats')[0].sku_count ? data('sku_kpi_stats')[0].capture_sku_count / data('sku_kpi_stats')[0].sku_count : 0" },
    { "name": "priceChangeSkuPct", "update": "data('sku_kpi_stats').length && data('sku_kpi_stats')[0].sku_count ? data('sku_kpi_stats')[0].price_change_sku_count / data('sku_kpi_stats')[0].sku_count : 0" },
    { "name": "exposedRevenue", "update": "data('sku_kpi_stats').length ? data('sku_kpi_stats')[0].exposed_ingresos : 0" },
    { "name": "visibleRevenue", "update": "data('sku_kpi_stats').length ? data('sku_kpi_stats')[0].visible_ingresos : 0" },
    { "name": "exposedRevenuePct", "update": "visibleRevenue ? exposedRevenue / visibleRevenue : 0" },
    { "name": "weightedElasticidad", "update": "data('sku_kpi_stats').length && data('sku_kpi_stats')[0].valid_elasticidad_ingresos_sum ? data('sku_kpi_stats')[0].weighted_elasticidad_sum / data('sku_kpi_stats')[0].valid_elasticidad_ingresos_sum : 0" },
    { "name": "weightedElasticidadLabel", "update": "data('sku_kpi_stats').length && data('sku_kpi_stats')[0].valid_elasticidad_ingresos_sum ? (weightedElasticidad >= 0 ? 'Atypical' : abs(weightedElasticidad) > 1.05 ? 'Elastic' : abs(weightedElasticidad) >= 0.95 ? 'Unit Elastic' : 'Inelastic') : 'No base'" },
    { "name": "weightedElasticidadColor", "update": "weightedElasticidadLabel === 'Elastic' ? '#a93f4b' : weightedElasticidadLabel === 'Unit Elastic' ? '#b87235' : weightedElasticidadLabel === 'Inelastic' ? '#3f6f95' : weightedElasticidadLabel === 'Atypical' ? '#764695' : '#52607a'" },
    { "name": "activeCategoryCount", "update": "data('active_categories').length" },
    { "name": "activeProductCount", "update": "data('active_products').length" },
    { "name": "showFocusedLatestPoint", "update": "activeCategoryCount == 1 || activeProductCount == 1" },
    { "name": "showProductTrace", "update": "activeProductCount === 1 && data('product_trace_points').length > 1" },
    { "name": "trendPointCount", "update": "data('product_trend_stats').length ? data('product_trend_stats')[0].n : 0" },
    { "name": "trendDenominator", "update": "data('product_trend_stats').length ? data('product_trend_stats')[0].n * data('product_trend_stats')[0].sum_x2 - data('product_trend_stats')[0].sum_x * data('product_trend_stats')[0].sum_x : 0" },
    { "name": "trendSlope", "update": "data('product_trend_stats').length && abs(trendDenominator) > 1e-9 ? (data('product_trend_stats')[0].n * data('product_trend_stats')[0].sum_xy - data('product_trend_stats')[0].sum_x * data('product_trend_stats')[0].sum_y) / trendDenominator : 0" },
    { "name": "trendIntercept", "update": "data('product_trend_stats').length && data('product_trend_stats')[0].n > 0 ? (data('product_trend_stats')[0].sum_y - trendSlope * data('product_trend_stats')[0].sum_x) / data('product_trend_stats')[0].n : 0" },
    { "name": "trendXStart", "update": "data('product_trend_extent').length ? data('product_trend_extent')[0].x_min : 0" },
    { "name": "trendXEnd", "update": "data('product_trend_extent').length ? data('product_trend_extent')[0].x_max : 0" },
    { "name": "showProductTrend", "update": "activeProductCount === 1 && trendPointCount >= 4 && abs(trendDenominator) > 1e-9 && trendXStart != trendXEnd" },
    {
      "name": "contextLabel",
      "update": "activeProductCount === 1 ? 'View: ' + data('active_products')[0].producto + ' | ' + data('active_products')[0].categoria : activeCategoryCount === 1 ? 'View: ' + data('active_categories')[0].categoria + ' | ' + format(activeProductCount, ',.0f') + ' products' : 'View: ' + format(activeCategoryCount, ',.0f') + ' categories | ' + format(activeProductCount, ',.0f') + ' products'"
    },
    {
      "name": "hoveredPointQuadrant",
      "value": null,
      "on": [
        {
          "events": "@scatter-points:mouseover",
          "update": "datum.delta_precio_pct < 0 && datum.delta_demanda_pct >= 0 ? 'topLeft' : datum.delta_precio_pct >= 0 && datum.delta_demanda_pct >= 0 ? 'topRight' : datum.delta_precio_pct < 0 && datum.delta_demanda_pct < 0 ? 'bottomLeft' : 'bottomRight'"
        },
        {
          "events": "@scatter-points:mouseout",
          "update": "null"
        }
      ]
    },
    {
      "name": "hoveredPoint",
      "value": null,
      "on": [
        {
          "events": "@scatter-points:mouseover",
          "update": "datum"
        },
        {
          "events": "@scatter-points:mouseout",
          "update": "null"
        }
      ]
    }
  ],
  "scales": [
    {
      "name": "x",
      "type": "linear",
      "domain": { "fields": [ { "data": "dataset", "field": "delta_precio_pct" } ] },
      "range": "width",
      "zero": true,
      "nice": true
    },
    {
      "name": "y",
      "type": "linear",
      "domain": { "fields": [ { "data": "dataset", "field": "delta_demanda_pct" } ] },
      "range": "height",
      "zero": true,
      "nice": true
    },
    {
      "name": "size",
      "type": "sqrt",
      "domain": { "data": "dataset", "field": "ingresos" },
      "range": [112, 380],
      "zero": true
    },
    {
      "name": "shape",
      "type": "ordinal",
      "domain": ["Elastic", "Unit Elastic", "Inelastic", "Atypical"],
      "range": ["triangle-up", "diamond", "circle", "square"]
    },
    {
      "name": "color",
      "type": "ordinal",
      "domain": ["Elastic", "Unit Elastic", "Inelastic", "Atypical"],
      "range": ["#e36b76", "#f9d5b1", "#c2d9e9", "#e5cef7"]
    },
    {
      "name": "strokeColor",
      "type": "ordinal",
      "domain": ["Elastic", "Unit Elastic", "Inelastic", "Atypical"],
      "range": ["#a93f4b", "#b87235", "#3f6f95", "#764695"]
    },
    {
      "name": "detailShape",
      "type": "ordinal",
      "domain": ["Elastic", "Unit Elastic", "Inelastic", "Atypical"],
      "range": ["triangle-down", "diamond", "circle", "cross"]
    }
  ],
  "axes": [
    {
      "orient": "bottom",
      "scale": "x",
      "title": "Price change vs previous period",
      "titlePadding": 14,
      "format": ".0%",
      "grid": true,
      "gridColor": "#e9edf5",
      "gridOpacity": 1,
      "labelFont": "Bahnschrift",
      "labelFontSize": 11,
      "labelColor": "#667085",
      "titleFont": "Bahnschrift SemiBold",
      "titleFontSize": 12,
      "titleColor": "#475467"
    },
    {
      "orient": "left",
      "scale": "y",
      "title": "Demand change vs previous period",
      "titlePadding": 16,
      "format": ".0%",
      "grid": true,
      "gridColor": "#e9edf5",
      "gridOpacity": 1,
      "labelFont": "Bahnschrift",
