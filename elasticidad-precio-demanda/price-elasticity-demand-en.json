          "x": { "scale": "x", "field": "delta_precio_pct" },
          "y": { "scale": "y", "field": "delta_demanda_pct" },
          "shape": { "scale": "detailShape", "field": "clasificacion" },
          "size": { "signal": "datum.clasificacion === 'Atypical' ? 34 : datum.clasificacion === 'Elastic' ? 28 : 20" },
          "fill": { "signal": "datum.clasificacion === 'Elastic' ? '#f7f5f2' : scale('strokeColor', datum.clasificacion)" },
          "stroke": { "signal": "datum.clasificacion === 'Elastic' ? scale('strokeColor', datum.clasificacion) : datum.clasificacion === 'Atypical' ? scale('strokeColor', datum.clasificacion) : 'transparent'" },
          "strokeWidth": { "signal": "datum.clasificacion === 'Elastic' || datum.clasificacion === 'Atypical' ? 0.8 : 0" },
          "opacity": { "value": 0.95 }
        }
      }
    },
    {
      "type": "symbol",
      "from": { "data": "product_trace_points" },
      "interactive": false,
      "encode": {
        "update": {
          "x": { "signal": "scale('x', datum.delta_precio_pct) + 12" },
          "y": { "signal": "scale('y', datum.delta_demanda_pct) - 12" },
          "shape": { "value": "circle" },
          "size": { "value": 180 },
          "fill": { "value": "white" },
          "stroke": { "value": "#98a2b3" },
          "strokeWidth": { "value": 1 },
          "opacity": { "signal": "activeProductCount === 1 ? 0.96 : 0" }
        }
      }
    },
    {
      "type": "text",
      "from": { "data": "product_trace_points" },
      "interactive": false,
      "encode": {
        "update": {
