          "y": { "signal": "scale('y', datum.delta_demanda_pct) - 12" },
          "text": { "signal": "toString(datum.trace_step)" },
          "font": { "value": "Bahnschrift SemiBold" },
          "fontSize": { "value": 8.5 },
          "fill": { "value": "#344054" },
          "align": { "value": "center" },
          "baseline": { "value": "middle" },
          "opacity": { "signal": "activeProductCount === 1 ? 1 : 0" }
        }
      }
    },
    {
      "type": "symbol",
      "from": { "data": "latest_context_point" },
      "interactive": false,
      "encode": {
        "update": {
          "x": { "scale": "x", "field": "delta_precio_pct" },
          "y": { "scale": "y", "field": "delta_demanda_pct" },
          "shape": { "scale": "shape", "field": "clasificacion" },
          "size": { "signal": "scale('size', datum.ingresos) + 90" },
